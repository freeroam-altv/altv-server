{
    "name": "@freero.am/altv-server",
    "version": "4.1.0",
    "description": "GTA V project",
    "type": "module",
    "scripts": {
        "clean": "rimraf ./resources",
        "build": "yarn clean && swc ./src -d ./resources --copy-files",
        "update": "altv-pkg d release",
        "update-webview": "git submodule update --remote && cd ./webview && yarn install",
        "build-webview": "cd ./webview && yarn build && copyfiles -u 1 \"./dist/**/*\" ../src/core/client/webview",
        "windows": "yarn update-webview && yarn build-webview && yarn build && altv-server.exe",
        "linux": "yarn update-webview && yarn build-webview && yarn build && ./start.sh",
        "windev": "nodemon --watch \"./src/**\" --ext \"ts\" --exec \"npm run build && altv-server.exe\"",
        "dev": "yarn update-webview && yarn build-webview && npm run windev",
        "reinstall": "rimraf node_modules && npm install",
        "test": "swc ./src",
        "lint": "yarn prettier --check ./src",
        "lint:fix": "yarn prettier --write ./src"
    },
    "author": "JustCup",
    "license": "ISC",
    "devDependencies": {
        "@altv/types-client": "^2.4.4",
        "@altv/types-natives": "^1.4.8",
        "@altv/types-server": "^2.5.7",
        "@altv/types-shared": "latest",
        "@altv/types-webview": "^1.0.5",
        "@swc/cli": "^0.1.57",
        "@swc/core": "^1.2.186",
        "@types/node": "^14.6.1",
        "altv-pkg": "^2.0.3",
        "copyfiles": "^2.4.1",
        "dotenv": "^16.0.3",
        "nodemon": "^2.0.16",
        "prettier": "^2.3.1",
        "rimraf": "^3.0.2",
        "tsup": "^4.11.2",
        "typescript": "latest"
    },
    "dependencies": {
        "nanoid": "^4.0.1",
        "node-vault": "^0.9.22"
    }
}
